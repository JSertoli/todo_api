// Prisma 7 — client novo (query compiler) + driver adapter (better-sqlite3).
// A URL do banco NÃO fica aqui: é injetada em prisma.config.ts a partir do .env.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// Usuário da aplicação. `password` guarda SEMPRE o hash bcrypt, nunca o texto puro.
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshTokens RefreshToken[]

  @@map("users")
}

/// Refresh tokens persistidos para permitir revogação (logout) e rotação.
/// Guardamos apenas o SHA-256 do token (tokenHash), nunca o valor entregue ao cliente.
model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}
